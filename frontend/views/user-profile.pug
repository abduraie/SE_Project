//- User Profile Page
extends layout

block content
  .container
      .profile-layout
            .profile-sidebar
                    .profile-card
                              .profile-avatar
                                          if profileUser.avatar_url
                                                        img(src=profileUser.avatar_url alt=profileUser.username)
                                                                    else
                                                                                  .avatar-large= profileUser.username.charAt(0).toUpperCase()

                                                                                            h1.profile-name= profileUser.full_name || profileUser.username
                                                                                                      p.profile-username @#{profileUser.username}
                                                                                                      
                                                                                                                if profileUser.bio
                                                                                                                            p.profile-bio= profileUser.bio
                                                                                                                            
                                                                                                                                      .profile-meta
                                                                                                                                                  if profileUser.location
                                                                                                                                                                .meta-item
                                                                                                                                                                                span.meta-icon 📍
                                                                                                                                                                                                span= profileUser.location
                                                                                                                                                                                                            if profileUser.website
                                                                                                                                                                                                                          .meta-item
                                                                                                                                                                                                                                          span.meta-icon 🔗
                                                                                                                                                                                                                                                          a(href=profileUser.website target="_blank")= profileUser.website
                                                                                                                                                                                                                                                                      .meta-item
                                                                                                                                                                                                                                                                                    span.meta-icon 📅
                                                                                                                                                                                                                                                                                                  span Member since #{new Date(profileUser.created_at).toLocaleDateString('en-US', {month: 'long', year: 'numeric'})}
                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                            .profile-stats
                                                                                                                                                                                                                                                                                                                        .stat-box
                                                                                                                                                                                                                                                                                                                                      span.stat-num= profileUser.listing_count || 0
                                                                                                                                                                                                                                                                                                                                                    span.stat-lbl Listings
                                                                                                                                                                                                                                                                                                                                                                .stat-box
                                                                                                                                                                                                                                                                                                                                                                              span.stat-num= profileUser.exchange_count || 0
                                                                                                                                                                                                                                                                                                                                                                                            span.stat-lbl Exchanges
                                                                                                                                                                                                                                                                                                                                                                                                        .stat-box
                                                                                                                                                                                                                                                                                                                                                                                                                      span.stat-num= profileUser.rating ? profileUser.rating.toFixed(1) : 'N/A'
                                                                                                                                                                                                                                                                                                                                                                                                                                    span.stat-lbl Rating
                                                                                                                                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                                                                                                                                              if currentUser && currentUser.id !== profileUser.id
                                                                                                                                                                                                                                                                                                                                                                                                                                                          .profile-actions
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        a.btn.btn-primary(href="/messages/new?to=" + profileUser.id) Send Message
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      a.btn.btn-outline(href="/listings?user=" + profileUser.id) View Listings
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              if profileUser.skills_offered && profileUser.skills_offered.length > 0
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        .skills-card
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    h3 Skills Offered
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                .skills-list
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              each skill in profileUser.skills_offered
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              span.skill-badge.offered= skill
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      if profileUser.skills_wanted && profileUser.skills_wanted.length > 0
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                .skills-card
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            h3 Skills Wanted
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        .skills-list
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      each skill in profileUser.skills_wanted
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      span.skill-badge.wanted= skill
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            .profile-main
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    .profile-tabs
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              button.tab-btn.active(data-tab="listings") Listings
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        button.tab-btn(data-tab="reviews") Reviews
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  button.tab-btn(data-tab="exchanges") Exchanges
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          .tab-content#listings.tab-panel.active
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    h2 Active Listings
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              if listings && listings.length > 0
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          .listings-grid
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        each listing in listings
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        .listing-card
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          .listing-card-header
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              span.category-badge= listing.category_name
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  span.status-badge(class=listing.status)= listing.status
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    h3.listing-title
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        a(href="/listings/" + listing.id)= listing.title
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          p.listing-excerpt= listing.description.substring(0, 120) + '...'
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            .listing-footer
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                span.date= new Date(listing.created_at).toLocaleDateString()
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    span.views= listing.views + ' views'
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              else
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          .empty-tab
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        p No active listings yet.
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                .tab-content#reviews.tab-panel
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          h2 Reviews
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    if reviews && reviews.length > 0
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                .reviews-list
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              each review in reviews
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              .review-card
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                .review-header
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    .reviewer-info
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          strong= review.reviewer_name
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                span.review-date= new Date(review.created_at).toLocaleDateString()
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    .star-rating
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          each i in [1,2,3,4,5]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  span(class=i <= review.rating ? 'star filled' : 'star') ★
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    p.review-text= review.comment
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              else
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          .empty-tab
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        p No reviews yet.
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                .tab-content#exchanges.tab-panel
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          h2 Past Exchanges
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    if exchanges && exchanges.length > 0
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                .exchanges-list
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              each exchange in exchanges
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              .exchange-card
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                .exchange-parties
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    span= exchange.provider_name
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        span.arrow ↔
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            span= exchange.requester_name
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              .exchange-details
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  span.exchange-date= new Date(exchange.completed_at).toLocaleDateString()
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      span.exchange-status= exchange.status
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                else
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            .empty-tab
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          p No completed exchanges yet.
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            script.
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                const tabBtns = document.querySelectorAll('.tab-btn');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    const tabPanels = document.querySelectorAll('.tab-panel');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        tabBtns.forEach(btn => {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              btn.addEventListener('click', () => {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      const target = btn.dataset.tab;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              tabBtns.forEach(b => b.classList.remove('active'));
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      tabPanels.forEach(p => p.classList.remove('active'));
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              btn.classList.add('active');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      document.getElementById(target).classList.add('active');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                });
