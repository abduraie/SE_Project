//- User Profile Page
extends layout

block content
  .container
    .profile-layout
      .profile-sidebar
        .profile-card
          .profile-avatar
            .avatar-large= (user.name || '?').charAt(0).toUpperCase()

          h1.profile-name= user.name
          if user.professional_title
            p.profile-title= user.professional_title

          if user.bio
            p.profile-bio= user.bio

          .profile-meta
            if user.location
              .meta-item
                span.meta-icon 📍
                span= user.location
            .meta-item
              span.meta-icon 📅
              span Member since #{new Date(user.member_since).toLocaleDateString('en-US', {month: 'long', year: 'numeric'})}

          .profile-stats
            .stat-box
              span.stat-num= listings ? listings.length : 0
              span.stat-lbl Listings
            .stat-box
              span.stat-num= user.active_count || 0
              span.stat-lbl Active
            .stat-box
              span.stat-num= user.rating ? Number(user.rating).toFixed(1) : 'N/A'
              span.stat-lbl Rating

      .profile-main
        h2 Active Listings
        if listings && listings.length > 0
          .listings-grid
            each listing in listings
              .listing-card
                .listing-card-header
                  span.category-badge= listing.category_name
                  span.status-badge(class=listing.status)= listing.status
                h3.listing-title
                  a(href="/listings/" + listing.id)= listing.title
                p.listing-excerpt= listing.description.substring(0, 120) + '...'
                .listing-footer
                  span.date= new Date(listing.created_at).toLocaleDateString()
                  span.views= listing.views + ' views'
        else
          .empty-tab
            p No active listings yet.
