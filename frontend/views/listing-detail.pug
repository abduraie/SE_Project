//- ============================================================================
//- Listing Detail Page
//- ============================================================================
//- Displays complete information about a single skill listing
//- ============================================================================

extends layout

block content
  .container
    .listing-detail
      .breadcrumb
        a(href="/") Home
        span  >
        a(href="/listings") Listings
        span  >
        span= listing.title

      .listing-content
        .listing-main
          .listing-detail-header
            span.category-badge= listing.category_name
            h1.listing-detail-title= listing.title

            .listing-metadata
              span.date Posted #{new Date(listing.created_at).toLocaleDateString()}
              span.status Status: #{listing.status}
              span.views #{listing.views} views

          .section
            h2 Description
            p.listing-full-description= listing.description

          .skills-exchange-section
            .skills-box
              h3 Offering
              if listing.skills_offered && listing.skills_offered.length > 0
                ul.skills-list
                  each skill in listing.skills_offered
                    li= skill
              else
                p.empty-text No skills specified

            .skills-box
              h3 Looking For
              if listing.skills_wanted && listing.skills_wanted.length > 0
                ul.skills-list
                  each skill in listing.skills_wanted
                    li= skill
              else
                p.empty-text No skills specified

          if listing.experience_level || listing.time_commitment || listing.duration
            .section
              h2 Collaboration Details
              .detail-grid
                if listing.experience_level
                  .detail-item
                    strong Experience Level:
                    span= listing.experience_level

                if listing.time_commitment
                  .detail-item
                    strong Time Commitment:
                    span= listing.time_commitment

                if listing.duration
                  .detail-item
                    strong Duration:
                    span= listing.duration

        .listing-sidebar
          .user-card
            h3 About the Provider

            .user-card-header
              h4
                a(href=`/users/${listing.user_id}`)= listing.user_name

              if listing.user_rating
                .rating
                  span.rating-value #{listing.user_rating}
                  span.rating-text Based on previous exchanges

              p.user-joined Member since #{new Date(listing.member_since).toLocaleDateString()}

            .user-actions
              a.btn.btn-primary.btn-block(href=`mailto:${listing.user_email}`) Contact
              a.btn.btn-secondary.btn-block(href=`/users/${listing.user_id}`) View Profile
