//- Users Page
extends layout

block content
  .container
    .page-header
      h1 Community Members
      p.subtitle Connect with skilled professionals in our community

    .search-filter-bar
      .search-box
        input.search-input(type="text" placeholder="Search users..." id="userSearch")

    if users && users.length > 0
      .users-grid#usersGrid
        each user in users
          .user-card
            .user-card-header
              .user-avatar
                .avatar-placeholder= (user.name || '?').charAt(0).toUpperCase()

            .user-card-body
              h3.user-name= user.name
              if user.professional_title
                p.user-title= user.professional_title

              if user.bio
                p.user-bio= user.bio

              if user.location
                .user-location
                  span.location-icon 📍
                  span= user.location

              .user-stats
                .stat
                  span.stat-number= user.active_count || 0
                  span.stat-label Active
                .stat
                  span.stat-number= user.success_rate != null ? user.success_rate + '%' : 'N/A'
                  span.stat-label Success
                .stat
                  span.stat-number= user.rating ? Number(user.rating).toFixed(1) : 'N/A'
                  span.stat-label Rating

            .user-card-footer
              a.btn.btn-outline(href="/users/" + user.id) View Profile
              a.btn.btn-primary(href="/listings?user=" + user.id) See Listings

    else
      .empty-state
        .empty-icon 👥
        h2 No users found
        p Try adjusting your search or filters
        a.btn.btn-primary(href="/listings") Browse Listings

  script.
    const searchInput = document.getElementById('userSearch');
    const usersGrid = document.getElementById('usersGrid');

    function filterUsers() {
      const query = searchInput.value.toLowerCase();
      const cards = usersGrid ? usersGrid.querySelectorAll('.user-card') : [];
      cards.forEach(card => {
        const name = card.querySelector('.user-name').textContent.toLowerCase();
        const match = !query || name.includes(query);
        card.style.display = match ? '' : 'none';
      });
    }

    if (searchInput) searchInput.addEventListener('input', filterUsers);
